diff --git a/lib/widgets/medicine_image.dart b/lib/widgets/medicine_image.dart
new file mode 100644
index 0000000..a03c217
--- /dev/null
+++ b/lib/widgets/medicine_image.dart
@@ -0,0 +1,41 @@
+import 'package:flutter/material.dart';
+import '../services/api_service.dart';
+
+/// Renders a [Medicine.imageAsset] regardless of whether it's a bundled
+/// Flutter asset (seed/demo data) or a real photo the backend stored after
+/// an AI scan (`/uploads/...`). Centralizing this avoids every screen
+/// re-implementing the asset-vs-network branch (and getting it wrong).
+class MedicineImage extends StatelessWidget {
+  final String imageAsset;
+  final BoxFit fit;
+
+  const MedicineImage({super.key, required this.imageAsset, this.fit = BoxFit.cover});
+
+  @override
+  Widget build(BuildContext context) {
+    if (ApiService.isNetworkImage(imageAsset)) {
+      return Image.network(
+        ApiService.resolveImageUrl(imageAsset),
+        fit: fit,
+        loadingBuilder: (context, child, progress) {
+          if (progress == null) return child;
+          return const Center(child: CircularProgressIndicator(strokeWidth: 2));
+        },
+        errorBuilder: (context, error, stackTrace) => Image.asset(
+          "assets/images/medicine_details.png",
+          fit: fit,
+        ),
+      );
+    }
+    return Image.asset(imageAsset, fit: fit);
+  }
+
+  /// Same resolution logic, exposed as a [DecorationImage] for screens
+  /// that build their photo via a BoxDecoration instead of a widget tree.
+  static ImageProvider provider(String imageAsset) {
+    if (ApiService.isNetworkImage(imageAsset)) {
+      return NetworkImage(ApiService.resolveImageUrl(imageAsset));
+    }
+    return AssetImage(imageAsset);
+  }
+}
