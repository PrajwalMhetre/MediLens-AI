+# ---------------------------------------------------------------------------
+# AI Medicine Scanning - the core MediLens feature
+# ---------------------------------------------------------------------------
+@app.post("/api/scan", response_model=schemas.ScanResponse)
+async def scan_medicine(file: UploadFile = File(...), db: Session = Depends(get_db)):
+    if file.content_type not in ALLOWED_IMAGE_TYPES:
+        raise HTTPException(
+            status_code=415,
+            detail=f"Unsupported image type '{file.content_type}'. Use JPEG, PNG, or WEBP.",
+        )
+
+    image_bytes = await file.read()
+    max_bytes = settings.max_upload_size_mb * 1024 * 1024
+    if len(image_bytes) > max_bytes:
+        raise HTTPException(status_code=413, detail=f"Image exceeds {settings.max_upload_size_mb}MB limit.")
+    if len(image_bytes) == 0:
+        raise HTTPException(status_code=400, detail="Empty file uploaded.")
+
+    # Persist the photo so the app can show what was scanned later.
+    ext = ALLOWED_IMAGE_TYPES[file.content_type]
+    filename = f"{uuid.uuid4().hex}.{ext}"
+    (settings.upload_dir / filename).write_bytes(image_bytes)
+    image_asset_path = f"/uploads/{filename}"
+
+    try:
+        result = ai_service.analyze_medicine_image(image_bytes, file.content_type)
+    except AIServiceError as exc:
+        logger.warning("Scan rejected: %s", exc)
+        raise HTTPException(status_code=422, detail=str(exc)) from exc
+
+    # Defense-in-depth: never rely solely on the LLM's own allergy judgement.
+    # Deterministically cross-check the scanned medicine name against the
+    # user's recorded allergies as well.
+    user = db.query(models.User).filter_by(email=DEFAULT_USER_EMAIL).first()
+    user_allergies = str_to_list(user.allergies) if user else []
+    name_lower = result.name.lower()
+    conflict_reason = None
+    deterministic_conflict = False
+    for allergy in user_allergies:
+        allergy_lower = allergy.lower().strip()
+        if allergy_lower and allergy_lower in name_lower:
+            deterministic_conflict = True
+            conflict_reason = f"Contains or relates to '{allergy}', which is listed in your allergy profile."
+            break
+    # Penicillin-class cross-reactivity is a well-known real-world case worth hardcoding.
+    if not deterministic_conflict and "penicillin" in [a.lower() for a in user_allergies]:
+        if any(k in name_lower for k in ("amoxicillin", "ampicillin", "penicillin")):
+            deterministic_conflict = True
+            conflict_reason = "Penicillin-class antibiotic - cross-reacts with your recorded Penicillin allergy."
+
+    is_conflict = deterministic_conflict or any("allerg" in w.lower() for w in result.warnings)
+    if deterministic_conflict:
+        warnings = [f"ALLERGY WARNING: {conflict_reason}"] + result.warnings
+    else:
+        warnings = result.warnings
+
+    db_med = models.Medicine(
+        name=result.name,
+        dosage=result.dosage,
+        frequency=result.frequency,
+        instructions=result.instructions,
+        image_asset=image_asset_path,
+        side_effects=list_to_str(result.side_effects),
+        warnings=list_to_str(warnings),
+        active_allergies_conflict=is_conflict,
+        time_list=list_to_str(result.time_list),
+    )
+    db.add(db_med)
+    db.commit()
+    db.refresh(db_med)
+
+    created_reminders = []
+    now = datetime.datetime.utcnow()
+    for t in result.time_list:
+        rem = models.MedicationReminder(
+            id=f"rem_{uuid.uuid4().hex[:10]}",
+            medicine_name=result.name,
+            dosage=result.dosage,
+            time=t,
+            is_taken=False,
+            date=now,
+        )
+        db.add(rem)
+        created_reminders.append(rem)
+    db.commit()
+    for rem in created_reminders:
+        db.refresh(rem)
+
+    return {
+        "medicine": map_medicine(db_med),
+        "reminders": created_reminders,
+        "ai_confidence": result.confidence,
+        "allergy_conflict": is_conflict,
+        "conflict_reason": conflict_reason,
+    }
+
