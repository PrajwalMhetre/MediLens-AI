+"""
+AI service layer — wraps all calls to the Anthropic Claude API.
+
+Two capabilities:
+  1. analyze_medicine_image(): multimodal (vision) call that turns a photo
+     of a medicine label/prescription into structured data.
+  2. get_ai_chat_response(): grounded conversational assistant that has
+     the user's profile + active medications injected as context.
+
+Design notes (why it's built this way):
+  - We never trust the LLM as the sole safety gate for allergy conflicts.
+    The model's flag is combined with a deterministic substring check in
+    `main.py` (defense in depth — a classic pattern for safety-critical
+    AI features).
+  - JSON is extracted defensively: models occasionally wrap JSON in
+    ```json fences even when told not to. We strip those before parsing.
+  - All network/parsing failures raise `AIServiceError` so the API
+    layer can translate them into clean HTTP responses instead of 500s.
+"""
+from __future__ import annotations
+
+import base64
+import json
+import logging
+import re
+from dataclasses import dataclass, field
+
+from anthropic import Anthropic, APIError, APIStatusError
+
+from config import get_settings
+
+logger = logging.getLogger("medilens.ai")
+
+settings = get_settings()
+_client: Anthropic | None = Anthropic(api_key=settings.anthropic_api_key) if settings.anthropic_api_key else None
+
+
+class AIServiceError(Exception):
+    """Raised whenever the AI layer cannot produce a usable result."""
+
+
+def is_ai_configured() -> bool:
+    return _client is not None
+
+
+_JSON_FENCE_RE = re.compile(r"```(?:json)?\s*(.*?)\s*```", re.DOTALL)
+
+
+def _extract_json(raw_text: str) -> dict:
+    """Pull a JSON object out of a model response, tolerating code fences."""
+    match = _JSON_FENCE_RE.search(raw_text)
+    candidate = match.group(1) if match else raw_text.strip()
+    try:
+        return json.loads(candidate)
+    except json.JSONDecodeError:
+        # Last resort: grab the widest {...} span in the text.
+        start, end = candidate.find("{"), candidate.rfind("}")
+        if start != -1 and end != -1 and end > start:
+            return json.loads(candidate[start : end + 1])
+        raise
+
+
+SCAN_SYSTEM_PROMPT = """You are the vision engine inside MediLens AI, a medication-safety app.
+You will be shown a photo of a medicine package, blister strip, bottle label, or prescription.
+
+Extract the medication information and respond with ONLY a single JSON object
+(no prose, no markdown fences) matching exactly this schema:
+
+{
+  "name": string,                 // Medicine / brand name as printed
+  "dosage": string,                // e.g. "500 mg"
+  "frequency": string,             // e.g. "Twice daily" (infer a sensible default if not printed)
+  "instructions": string,          // Plain-language usage instructions
+  "side_effects": [string, ...],   // 2-5 common side effects
+  "warnings": [string, ...],       // 2-4 important safety warnings, plain language
+  "time_list": [string, ...],      // Suggested reminder times in "HH:MM AM/PM" format, count matching frequency
+  "confidence": number,            // 0.0-1.0 how confident you are this is a correctly read label
+  "is_readable": boolean           // false if the image is too blurry/dark/incomplete to identify a medicine
+}
+
+Rules:
+- If the image clearly is NOT a medicine label/prescription (e.g. random object), set is_readable to false,
+  name to "Unknown", and leave arrays empty.
+- Never invent a dosage you cannot read; if unclear, make your best estimate and lower "confidence" instead of failing.
+- Keep every string concise (under 140 characters) and free of medical jargon where possible.
+- Do not include any text outside the JSON object."""
+
+
+@dataclass
+class ScanResult:
+    name: str
+    dosage: str
+    frequency: str
+    instructions: str
+    side_effects: list[str] = field(default_factory=list)
+    warnings: list[str] = field(default_factory=list)
+    time_list: list[str] = field(default_factory=list)
+    confidence: float = 0.0
+    is_readable: bool = True
+
+
+def analyze_medicine_image(image_bytes: bytes, mime_type: str) -> ScanResult:
+    if _client is None:
+        raise AIServiceError(
+            "ANTHROPIC_API_KEY is not configured on the server. "
+            "Set it in backend/.env to enable real medicine scanning."
+        )
+
+    b64_image = base64.b64encode(image_bytes).decode("utf-8")
+
+    try:
+        response = _client.messages.create(
+            model=settings.anthropic_vision_model,
+            max_tokens=1024,
+            system=SCAN_SYSTEM_PROMPT,
+            messages=[
+                {
+                    "role": "user",
+                    "content": [
+                        {
+                            "type": "image",
+                            "source": {
+                                "type": "base64",
+                                "media_type": mime_type,
+                                "data": b64_image,
+                            },
+                        },
+                        {
+                            "type": "text",
+                            "text": "Identify this medicine and return the JSON object described in your instructions.",
+                        },
+                    ],
+                }
+            ],
+        )
+    except (APIError, APIStatusError) as exc:
+        logger.exception("Anthropic vision call failed")
+        raise AIServiceError(f"AI scanning service unavailable: {exc}") from exc
+
+    raw_text = "".join(block.text for block in response.content if block.type == "text")
+    try:
+        parsed = _extract_json(raw_text)
+    except (json.JSONDecodeError, ValueError) as exc:
+        logger.error("Could not parse AI scan response: %s", raw_text)
+        raise AIServiceError("AI returned an unreadable response. Please retake the photo.") from exc
+
+    if not parsed.get("is_readable", True):
+        raise AIServiceError(
+            "Couldn't confidently read a medicine label in this photo. "
+            "Try better lighting and keep the label flat and centered."
+        )
+
+    return ScanResult(
+        name=str(parsed.get("name", "Unknown Medicine")).strip(),
+        dosage=str(parsed.get("dosage", "N/A")).strip(),
+        frequency=str(parsed.get("frequency", "As directed")).strip(),
+        instructions=str(parsed.get("instructions", "Follow the printed label instructions.")).strip(),
+        side_effects=[str(s).strip() for s in parsed.get("side_effects", [])][:6],
+        warnings=[str(w).strip() for w in parsed.get("warnings", [])][:6],
+        time_list=[str(t).strip() for t in parsed.get("time_list", [])][:6] or ["08:00 AM"],
+        confidence=float(parsed.get("confidence", 0.5)),
+        is_readable=True,
+    )
+
+
+CHAT_SYSTEM_PROMPT_TEMPLATE = """You are the MediLens AI Pharmacist — a friendly, careful medication-safety
+assistant embedded in a mobile app. You are NOT a doctor and must never
+present yourself as one.
+
+Patient profile:
+- Name: {name}
+- Blood type: {blood_type}
+- Weight: {weight}
+- Known allergies: {allergies}
+
+Active medications:
+{medicines}
+
+Guidelines:
+- Ground every answer in the patient profile above when relevant (e.g. flag allergy conflicts explicitly).
+- Be concise: 2-5 sentences unless the user asks for detail.
+- Always recommend consulting a licensed clinician for diagnosis, dosage changes, or anything urgent.
+- If asked something outside medication safety/scheduling, gently redirect to what you can help with.
+- Never invent drug interaction data you're not confident about — say so plainly instead."""
+
+
+def get_ai_chat_response(
+    user_message: str,
+    user_name: str,
+    blood_type: str,
+    weight: str,
+    allergies: list[str],
+    medicines: list[str],
+    history: list[tuple[str, bool]],
+) -> str:
+    """history: list of (text, is_user) tuples, oldest first, already excluding user_message."""
+    if _client is None:
+        raise AIServiceError("ANTHROPIC_API_KEY is not configured on the server.")
+
+    system_prompt = CHAT_SYSTEM_PROMPT_TEMPLATE.format(
+        name=user_name,
+        blood_type=blood_type,
+        weight=weight,
+        allergies=", ".join(allergies) if allergies else "None recorded",
+        medicines="\n".join(f"- {m}" for m in medicines) if medicines else "- None recorded",
+    )
+
+    messages = []
+    for text, is_user in history[-10:]:
+        messages.append({"role": "user" if is_user else "assistant", "content": text})
+    messages.append({"role": "user", "content": user_message})
+
+    try:
+        response = _client.messages.create(
+            model=settings.anthropic_chat_model,
+            max_tokens=500,
+            system=system_prompt,
+            messages=messages,
+        )
+    except (APIError, APIStatusError) as exc:
+        logger.exception("Anthropic chat call failed")
+        raise AIServiceError(f"AI chat service unavailable: {exc}") from exc
+
+    return "".join(block.text for block in response.content if block.type == "text").strip()
